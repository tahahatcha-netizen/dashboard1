function renderBIM(){
  const grid=document.getElementById('bim-grid');
  const mode=document.getElementById('colorMode').value;
  const roomCount=(DATA.floors[bimBuilding]||{})[bimFloor]||20;
  const label=bimFloor==='-1'?'Untergeschoss':bimFloor==='0'?'Erdgeschoss':bimFloor+'. Obergeschoss';
  document.getElementById('bim-info').textContent=`Gebäude ${bimBuilding} · ${label}`;
  const cats=['Klinik','Patient','Verkehrsfläche','Verwaltung','Technikfläche/Logistik/Infrastruktur'];
  const catC=['#185FA5','#0F6E56','#888780','#534AB7','#BA7517'];
  const fbs=['Pflege','ZOP','ITS','Kardiologie','Psychiatrie','AKH','Neurologie'];
  const fbC=['#0F6E56','#1D9E75','#E24B4A','#378add','#534AB7','#888780','#0F6E56'];
  const raum=['Patientenzimmer','Büro','Flure','WC/Sanitär','OP-Nebenräume','Intensiv'];
  const raumC=['#0F6E56','#534AB7','#888780','#378add','#E24B4A','#D85A30'];

  let cells='';
  const cols=Math.min(roomCount,10);
  const rows=Math.ceil(roomCount/cols);
  const legend={};
  for(let i=0;i<roomCount;i++){
    let color,label2,key;
    if(mode==='kategorie'){const idx=Math.floor(Math.random()*cats.length);key=cats[idx];color=catC[idx];}
    else if(mode==='fachbereich'){const idx=Math.floor(Math.random()*fbs.length);key=fbs[idx];color=fbC[idx];}
    else{const idx=Math.floor(Math.random()*raum.length);key=raum[idx];color=raumC[idx];}
    legend[key]=color;
    const area=(10+Math.random()*40).toFixed(1);
    cells+=`<div class="bim-cell" style="background:${color};opacity:0.82" onclick="showRoomDetail('Raum ${bimBuilding}-${bimFloor}-${String(i+1).padStart(3,'0')}','${key}',${area})" title="${key}: ${area} m²"></div>`;
  }
  grid.style.gridTemplateColumns=`repeat(${cols},1fr)`;
  grid.innerHTML=cells;
  const legEl=document.getElementById('bim-legend');
  legEl.innerHTML=Object.entries(legend).map(([k,c])=>`<span style="display:flex;align-items:center;gap:3px"><span style="width:8px;height:8px;border-radius:1px;background:${c};flex-shrink:0"></span><span style="color:var(--color-text-secondary)">${k}</span></span>`).join('');
