function makeBarRows(containerId,data,colorFn,maxVal,unit=''){
  const c=document.getElementById(containerId);
  if(!c)return;
  c.innerHTML='';
  const mx=maxVal||Math.max(...data.map(d=>d.v||d.area||0));
  data.forEach(d=>{
    const v=d.v||d.area||0;
    const lbl=d.n||d.name||d.g||'';
    const pct=mx>0?Math.round(v/mx*100):0;
    const color=colorFn?colorFn(lbl):'#378add';
    c.innerHTML+=`<div class="bar-row"><div class="bar-label" title="${lbl}">${lbl}</div><div class="bar-track"><div class="bar-fill" style="width:${pct}%;background:${color}"></div></div><div class="bar-val">${unit}${v.toLocaleString('de-DE')}</div></div>`;
  });
}

