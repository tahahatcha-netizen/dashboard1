  if(chips.innerHTML===''){
    ['AKH','Psychiatrie','Gynäkologie','Kardiologie','ZOP','ITS','Herzchirurgie','Neurologie','ZNA','Orthopädie/ MIC-Klinik','WL-Station','ADW'].forEach(d=>{
      const c=document.createElement('div');
      c.className='filter-chip'+(d==='AKH'?' active':'');
      c.textContent=d;
      c.onclick=()=>{document.querySelectorAll('#dept-chips .filter-chip').forEach(x=>x.classList.remove('active'));c.classList.add('active');selectedDept=d;updateDeptDrilldown();};
      chips.appendChild(c);
    });
  }
  updateDeptDrilldown();
}

function updateDeptDrilldown(){
  const d=DATA.depts.find(x=>x.name===selectedDept)||{name:selectedDept,area:1000};
  const rms=allRooms.filter(r=>r.fb===selectedDept||selectedDept==='AKH');
  const kpis=document.getElementById('dept-kpis');
  kpis.innerHTML=`
    <div class="kpi accent"><div class="kpi-label">Fläche</div><div class="kpi-val">${d.area.toLocaleString('de-DE')}</div><div class="kpi-sub">m²</div></div>
    <div class="kpi info"><div class="kpi-label">Räume (Probe)</div><div class="kpi-val">${rms.length}</div></div>
    <div class="kpi"><div class="kpi-label">Ø Raumgröße</div><div class="kpi-val">${rms.length>0?(rms.reduce((s,r)=>s+r.m2,0)/rms.length).toFixed(1):'–'}</div><div class="kpi-sub">m²</div></div>
    <div class="kpi warn"><div class="kpi-label">Anteil Gesamt</div><div class="kpi-val">${(d.area/58562*100).toFixed(1)}%</div></div>`;
  const raTypes={};
  rms.forEach(r=>{raTypes[r.raumart]=(raTypes[r.raumart]||0)+1;});
  makeBarRows('dept-raumart',Object.entries(raTypes).map(([n,v])=>({n,v})).sort((a,b)=>b.v-a.v),()=>'#185FA5',null,'');
  const bTypes={};
  rms.forEach(r=>{bTypes['Haus '+r.gebaeude]=(bTypes['Haus '+r.gebaeude]||0)+1;});
  makeBarRows('dept-bldg',Object.entries(bTypes).map(([n,v])=>({n,v})).sort((a,b)=>b.v-a.v),(n)=>bldgColor(n.replace('Haus ','')),null,'');
}

function initRooms(){
  filterRooms();
}

function filterRooms(){
  const q=(document.getElementById('room-search').value||'').toLowerCase();
  const g=document.getElementById('room-gebaeude').value;
  const k=document.getElementById('room-kat').value;
  filteredRooms=allRooms.filter(r=>{
    const matchQ=!q||(r.bez.toLowerCase().includes(q)||r.nr.toLowerCase().includes(q)||r.fb.toLowerCase().includes(q));
    const matchG=!g||r.gebaeude===g;
    const matchK=!k||r.kat===k;
    return matchQ&&matchG&&matchK;
  });
  renderRooms();
}

const BADGE_CLASS={Klinik:'badge-klinik',Patient:'badge-pflege','Technikfläche/Logistik/Infrastruktur':'badge-tech',Verwaltung:'badge-verwaltung',Verkehrsfläche:'badge-verkehr'};

function renderRooms(){
  const list=document.getElementById('room-list');
  document.getElementById('room-count').textContent=`${filteredRooms.length} von ${allRooms.length} Räumen`;
  if(filteredRooms.length===0){list.innerHTML='<div style="color:var(--color-text-secondary);font-size:12px;padding:8px">Keine Räume gefunden.</div>';return;}
  list.innerHTML=filteredRooms.map(r=>`
    <div class="room-row" onclick="sendPrompt('Zeige Details zu Raum ${r.nr}: ${r.bez}, Fachbereich ${r.fb}, ${r.m2} m²')">
      <div style="width:90px;flex-shrink:0;font-size:11px;font-weight:500;color:var(--color-text-primary)">${r.nr}</div>
      <div style="flex:1;min-width:0"><div style="font-size:11px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${r.bez}</div><div style="font-size:10px;color:var(--color-text-secondary)">${r.fb} · KST ${r.kst}</div></div>
      <div style="width:60px;text-align:right;font-size:11px;color:var(--color-text-secondary)">${r.m2} m²</div>
      <div style="width:80px;text-align:right"><span class="badge ${BADGE_CLASS[r.kat]||'badge-verkehr'}">${r.kat}</span></div>
    </div>`).join('');
}

document.addEventListener('DOMContentLoaded',()=>{});
window.addEventListener('load',()=>{
  initOverview();
});
setTimeout(()=>{initOverview();},100);
</script>
