
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#0f2744;--navy2:#1a3a5c;--accent:#1d9e75;--accent2:#378add;
  --warn:#ef9f27;--danger:#e24b4a;--text1:var(--color-text-primary);
  --text2:var(--color-text-secondary);--bg1:var(--color-background-primary);
  --bg2:var(--color-background-secondary);--bg3:var(--color-background-tertiary);
  --border:var(--color-border-tertiary);
}
body{font-family:var(--font-sans);font-size:13px;color:var(--text1)}
.shell{display:flex;height:820px;overflow:hidden;border:0.5px solid var(--border);border-radius:var(--border-radius-lg);background:var(--bg3)}
.sidebar{width:200px;flex-shrink:0;background:var(--bg1);border-right:0.5px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.sb-logo{padding:14px 14px 10px;border-bottom:0.5px solid var(--border)}
.sb-logo span{font-size:11px;font-weight:500;color:var(--text2);display:block;margin-top:2px}
.sb-logo strong{font-size:13px;color:var(--text1)}
.sb-nav{flex:1;overflow-y:auto;padding:8px 0}
.sb-section{padding:4px 12px;font-size:10px;font-weight:500;color:var(--text2);text-transform:uppercase;letter-spacing:.05em;margin-top:8px}
.nav-item{display:flex;align-items:center;gap:8px;padding:6px 12px;cursor:pointer;border-radius:0;font-size:12px;color:var(--text2);transition:background .15s}
.nav-item:hover{background:var(--bg2);color:var(--text1)}
.nav-item.active{background:var(--bg2);color:var(--text1);border-right:2px solid var(--accent)}
.nav-item i{font-size:15px;flex-shrink:0}
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
.topbar{height:44px;padding:0 16px;display:flex;align-items:center;justify-content:space-between;background:var(--bg1);border-bottom:0.5px solid var(--border);flex-shrink:0}
.topbar-title{font-size:14px;font-weight:500}
.topbar-pills{display:flex;gap:6px}
.pill{padding:3px 10px;border-radius:20px;font-size:11px;cursor:pointer;border:0.5px solid var(--border);color:var(--text2);background:var(--bg1)}
.pill.active{background:var(--accent);color:#fff;border-color:var(--accent)}
.content{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:12px}
.page{display:none}
.page.active{display:flex;flex-direction:column;gap:12px}
.kpi-row{display:grid;grid-template-columns:repeat(6,1fr);gap:8px}
.kpi{background:var(--bg1);border:0.5px solid var(--border);border-radius:var(--border-radius-md);padding:10px 12px}
.kpi-label{font-size:10px;color:var(--text2);margin-bottom:4px}
.kpi-val{font-size:20px;font-weight:500}
.kpi-sub{font-size:10px;color:var(--text2);margin-top:2px}
.kpi.accent{border-left:2px solid var(--accent)}
.kpi.info{border-left:2px solid var(--accent2)}
.kpi.warn{border-left:2px solid var(--warn)}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
.card{background:var(--bg1);border:0.5px solid var(--border);border-radius:var(--border-radius-md);padding:12px}
.card-title{font-size:11px;font-weight:500;color:var(--text2);margin-bottom:10px;display:flex;align-items:center;gap:6px}
.chart-wrap{position:relative}
.bim-grid{display:grid;grid-template-columns:repeat(10,1fr);gap:3px;padding:4px}
.bim-cell{aspect-ratio:1;border-radius:2px;cursor:pointer;transition:opacity .15s,transform .1s}
.bim-cell:hover{opacity:.7;transform:scale(1.15)}
.bim-cell.selected{ring:2px solid white;opacity:1}
.floor-btn{padding:3px 8px;border-radius:4px;border:0.5px solid var(--border);background:var(--bg2);font-size:11px;cursor:pointer;color:var(--text2)}
.floor-btn.active{background:var(--accent2);color:#fff;border-color:var(--accent2)}
.org-domain{display:flex;flex-direction:column;gap:3px}
.org-header{padding:5px 8px;border-radius:4px;font-size:11px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:space-between}
.org-children{margin-left:12px;display:flex;flex-direction:column;gap:2px}
.org-child{padding:3px 8px;border-radius:3px;font-size:10px;cursor:pointer;color:var(--text2);display:flex;justify-content:space-between;align-items:center}
.org-child:hover{background:var(--bg2);color:var(--text1)}
.org-child.sel{background:var(--bg2);color:var(--text1);font-weight:500}
.bar-row{display:flex;align-items:center;gap:6px;margin-bottom:5px}
.bar-label{font-size:10px;color:var(--text2);width:90px;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.bar-track{flex:1;height:8px;background:var(--bg2);border-radius:4px;overflow:hidden}
.bar-fill{height:100%;border-radius:4px;transition:width .5s ease}
.bar-val{font-size:10px;color:var(--text2);width:52px;text-align:right;flex-shrink:0}
.room-row{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:0.5px solid var(--border);cursor:pointer}
.room-row:hover{background:var(--bg2)}
.badge{padding:2px 6px;border-radius:10px;font-size:9px;font-weight:500}
.badge-klinik{background:#E6F1FB;color:#0C447C}
.badge-pflege{background:#E1F5EE;color:#085041}
.badge-tech{background:#FAEEDA;color:#633806}
.badge-verwaltung{background:#EEEDFE;color:#3C3489}
.badge-verkehr{background:#F1EFE8;color:#444441}
.treemap-cell{position:absolute;display:flex;align-items:flex-end;padding:4px;overflow:hidden;cursor:pointer;border:1.5px solid var(--bg3);transition:opacity .15s}
.treemap-cell:hover{opacity:.8}
.treemap-label{font-size:9px;font-weight:500;color:rgba(255,255,255,.9);line-height:1.2;pointer-events:none}
.filter-row{display:flex;gap:6px;flex-wrap:wrap}
.filter-chip{padding:3px 8px;border-radius:12px;border:0.5px solid var(--border);font-size:11px;cursor:pointer;color:var(--text2);background:var(--bg1)}
.filter-chip.active{background:var(--navy2);color:#fff;border-color:var(--navy2)}
.stat-row{display:flex;justify-content:space-between;padding:5px 0;border-bottom:0.5px solid var(--border);font-size:11px}
.stat-row:last-child{border:none}
.heatmap-wrap{display:grid;grid-template-columns:repeat(9,1fr);gap:2px}
.hmap-cell{border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:500;color:rgba(255,255,255,.85);min-height:28px;cursor:pointer}
.breadcrumb{font-size:11px;color:var(--text2);display:flex;align-items:center;gap:4px}
.breadcrumb span{cursor:pointer}
.breadcrumb span:hover{color:var(--text1)}
.drilldown-kpi{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:10px}
</style>

<h2 class="sr-only">Albertinen Krankenhaus Digital Twin Dashboard — interactive space and organizational analytics</h2>

<div class="shell">
<div class="sidebar">
  <div class="sb-logo">
    <strong>AKH Digital Twin</strong>
    <span>Albertinen Krankenhaus</span>
  </div>
  <div class="sb-nav">
    <div class="sb-section">Analyse</div>
    <div class="nav-item active" onclick="showPage('overview',this)"><i class="ti ti-dashboard" aria-hidden="true"></i> Executive Overview</div>
    <div class="nav-item" onclick="showPage('bim',this)"><i class="ti ti-building" aria-hidden="true"></i> BIM Space Explorer</div>
    <div class="nav-item" onclick="showPage('org',this)"><i class="ti ti-sitemap" aria-hidden="true"></i> Org Analyse</div>
    <div class="nav-item" onclick="showPage('space',this)"><i class="ti ti-layout" aria-hidden="true"></i> Space Analytics</div>
    <div class="sb-section">Details</div>
    <div class="nav-item" onclick="showPage('dept',this)"><i class="ti ti-stethoscope" aria-hidden="true"></i> Fachbereich Deep Dive</div>
    <div class="nav-item" onclick="showPage('rooms',this)"><i class="ti ti-door" aria-hidden="true"></i> Room Explorer</div>
    <div class="sb-section">Infrastruktur</div>
    <div class="nav-item" onclick="showPage('datamodel',this)"><i class="ti ti-database" aria-hidden="true"></i> Datenmodell</div>
  </div>
</div>

<div class="main">
  <div class="topbar">
    <div class="topbar-title" id="page-title">Executive Overview</div>
    <div style="display:flex;gap:8px;align-items:center">
      <div class="breadcrumb" id="breadcrumb"><span>AKH</span></div>
      <div style="display:flex;gap:4px">
        <div class="filter-chip active" onclick="toggleFilter(this,'all')">Alle Gebäude</div>
        <div class="filter-chip" onclick="toggleFilter(this,'A')">Haus A</div>
        <div class="filter-chip" onclick="toggleFilter(this,'C')">Haus C</div>
        <div class="filter-chip" onclick="toggleFilter(this,'F')">Haus F</div>
      </div>
    </div>
  </div>

  <div class="content">

  <!-- PAGE 1: EXECUTIVE OVERVIEW -->
  <div class="page active" id="page-overview">
    <div class="kpi-row">
      <div class="kpi accent"><div class="kpi-label">Gesamtfläche</div><div class="kpi-val">58.562</div><div class="kpi-sub">m² gesamt</div></div>
      <div class="kpi info"><div class="kpi-label">Räume</div><div class="kpi-val">3.376</div><div class="kpi-sub">Raumeinheiten</div></div>
      <div class="kpi"><div class="kpi-label">Gebäude</div><div class="kpi-val">10</div><div class="kpi-sub">Haus A–K</div></div>
      <div class="kpi"><div class="kpi-label">Etagen</div><div class="kpi-val">9</div><div class="kpi-sub">UG–7.OG</div></div>
      <div class="kpi warn"><div class="kpi-label">Fachbereiche</div><div class="kpi-val">105</div><div class="kpi-sub">Organisationseinheiten</div></div>
      <div class="kpi"><div class="kpi-label">Kostenstellen</div><div class="kpi-val">110</div><div class="kpi-sub">KST aktiv</div></div>
    </div>
    <div class="two-col">
      <div class="card">
        <div class="card-title"><i class="ti ti-building" aria-hidden="true"></i> Fläche je Gebäude</div>
        <div id="bldg-bars"></div>
      </div>
      <div class="card">
        <div class="card-title"><i class="ti ti-medical-cross" aria-hidden="true"></i> Top-Fachbereiche nach Fläche</div>
        <div id="dept-bars"></div>
      </div>
    </div>
    <div class="two-col">
      <div class="card">
        <div class="card-title"><i class="ti ti-layout-grid" aria-hidden="true"></i> Raumkategorien</div>
        <div class="chart-wrap" style="height:160px"><canvas id="catChart" role="img" aria-label="Pie chart of room categories">Klinik 859, Technik 827, Patient 747, Verkehr 469, Verwaltung 203.</canvas></div>
      </div>
      <div class="card">
        <div class="card-title"><i class="ti ti-chart-bar" aria-hidden="true"></i> Raumarten (Top 8)</div>
        <div id="raumart-bars"></div>
      </div>
    </div>
  </div>

  <!-- PAGE 2: BIM SPACE EXPLORER -->
  <div class="page" id="page-bim">
    <div style="display:flex;gap:8px;margin-bottom:6px;flex-wrap:wrap">
      <div class="card" style="flex:1;min-width:160px">
        <div class="card-title">Gebäude wählen</div>
        <div style="display:flex;gap:4px;flex-wrap:wrap" id="bldg-btns"></div>
      </div>
      <div class="card" style="flex:1;min-width:100px">
        <div class="card-title">Etage</div>
        <div style="display:flex;gap:4px;flex-wrap:wrap" id="floor-btns"></div>
      </div>
      <div class="card" style="flex:0 0 130px">
        <div class="card-title">Farbkodierung</div>
        <select id="colorMode" onchange="renderBIM()" style="width:100%;font-size:11px">
          <option value="kategorie">Kategorie</option>
          <option value="fachbereich">Fachbereich</option>
          <option value="raumart">Raumart</option>
        </select>
        <div id="bim-legend" style="margin-top:8px;font-size:9px;display:flex;flex-direction:column;gap:2px"></div>
      </div>
    </div>
    <div class="card" style="flex:1">
      <div class="card-title"><i class="ti ti-building" aria-hidden="true"></i> Grundriss-Simulation — <span id="bim-info">Gebäude A · Erdgeschoss</span></div>
      <div style="display:flex;gap:12px">
        <div style="flex:1">
          <div class="bim-grid" id="bim-grid" style="background:var(--bg2);border-radius:6px;min-height:300px"></div>
        </div>
        <div style="width:180px">
          <div style="font-size:10px;font-weight:500;color:var(--text2);margin-bottom:6px">Raumdetail</div>
          <div id="bim-detail" style="font-size:11px;color:var(--text2)">Raum auswählen...</div>
          <div style="margin-top:12px;font-size:10px;font-weight:500;color:var(--text2)">Etagen-KPIs</div>
          <div id="floor-kpis" style="margin-top:4px"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- PAGE 3: ORG ANALYSE -->
  <div class="page" id="page-org">
    <div class="two-col" style="align-items:start">
      <div class="card" style="overflow-y:auto;max-height:680px">
        <div class="card-title"><i class="ti ti-sitemap" aria-hidden="true"></i> Organisationshierarchie</div>
        <div id="org-tree" style="display:flex;flex-direction:column;gap:6px"></div>
      </div>
      <div style="display:flex;flex-direction:column;gap:12px">
        <div class="card">
          <div class="card-title"><i class="ti ti-chart-treemap" aria-hidden="true"></i> Treemap — Fläche je Domäne</div>
          <div style="position:relative;height:200px;width:100%" id="treemap"></div>
        </div>
        <div class="card">
          <div class="card-title"><i class="ti ti-chart-donut" aria-hidden="true"></i> Domänen-Verteilung</div>
          <div style="height:200px;position:relative"><canvas id="domChart" role="img" aria-label="Donut chart of space by domain">AKH 23%, Psychiatrie 7%, Gynäkologie 4%, ZOP 4%.</canvas></div>
        </div>
      </div>
    </div>
  </div>

  <!-- PAGE 4: SPACE ANALYTICS -->
  <div class="page" id="page-space">
    <div class="kpi-row" style="grid-template-columns:repeat(3,1fr)">
      <div class="kpi accent"><div class="kpi-label">Ø Fläche je Raum</div><div class="kpi-val">17,3 m²</div></div>
      <div class="kpi info"><div class="kpi-label">Größtes Gebäude</div><div class="kpi-val">Haus C</div><div class="kpi-sub">19.554 m²</div></div>
      <div class="kpi warn"><div class="kpi-label">Fehlende KST-Zuordnung</div><div class="kpi-val">2.730</div><div class="kpi-sub">Räume ohne KST Gruppe</div></div>
    </div>
    <div class="card">
      <div class="card-title"><i class="ti ti-grid-dots" aria-hidden="true"></i> Heatmap — Räume je Gebäude × Etage</div>
      <div style="margin-bottom:6px;font-size:10px;color:var(--text2)">Anzahl Räume (dunkel = mehr Räume)</div>
      <div id="heatmap-labels" style="display:grid;grid-template-columns:50px repeat(10,1fr);gap:2px;font-size:9px;text-align:center;color:var(--text2);margin-bottom:2px"></div>
      <div id="heatmap-rows" style="display:flex;flex-direction:column;gap:2px"></div>
    </div>
    <div class="two-col">
      <div class="card">
        <div class="card-title"><i class="ti ti-chart-bar" aria-hidden="true"></i> Fläche je Etage (Gesamt)</div>
        <div id="etage-bars"></div>
      </div>
      <div class="card">
        <div class="card-title"><i class="ti ti-home" aria-hidden="true"></i> Fußbodenbelag-Verteilung</div>
        <div class="chart-wrap" style="height:180px"><canvas id="bodenChart" role="img" aria-label="Bar chart of flooring types">Stein, Linoleum, Fliesen, PVC, Holz.</canvas></div>
      </div>
    </div>
  </div>

  <!-- PAGE 5: DEPT DEEP DIVE -->
  <div class="page" id="page-dept">
    <div style="margin-bottom:8px">
      <div class="card-title" style="margin-bottom:6px">Fachbereich auswählen</div>
      <div class="filter-row" id="dept-chips"></div>
    </div>
    <div class="drilldown-kpi" id="dept-kpis"></div>
    <div class="two-col">
      <div class="card">
        <div class="card-title"><i class="ti ti-door" aria-hidden="true"></i> Räume nach Typ</div>
        <div id="dept-raumart"></div>
      </div>
      <div class="card">
        <div class="card-title"><i class="ti ti-building" aria-hidden="true"></i> Räume je Gebäude</div>
        <div id="dept-bldg"></div>
      </div>
    </div>
  </div>

  <!-- PAGE 6: ROOM EXPLORER -->
  <div class="page" id="page-rooms">
    <div style="display:flex;gap:8px;margin-bottom:4px">
      <input type="text" id="room-search" placeholder="Raum suchen..." oninput="filterRooms()" style="flex:1;font-size:12px">
      <select id="room-gebaeude" onchange="filterRooms()" style="font-size:12px">
        <option value="">Alle Gebäude</option>
        <option>A</option><option>B</option><option>C</option><option>D</option>
        <option>E</option><option>F</option><option>G</option><option>H</option>
        <option>I</option><option>K</option>
      </select>
      <select id="room-kat" onchange="filterRooms()" style="font-size:12px">
        <option value="">Alle Kategorien</option>
        <option>Klinik</option><option>Patient</option><option>Verkehrsfläche</option>
        <option>Verwaltung</option><option>Technikfläche/Logistik/Infrastruktur</option>
      </select>
    </div>
    <div class="card" style="overflow-y:auto;max-height:660px">
      <div id="room-count" style="font-size:10px;color:var(--text2);margin-bottom:8px"></div>
      <div id="room-list"></div>
    </div>
  </div>

  <!-- PAGE 7: DATA MODEL -->
  <div class="page" id="page-datamodel">
    <div class="card">
      <div class="card-title"><i class="ti ti-database" aria-hidden="true"></i> Star Schema — Empfohlenes Power BI Datenmodell</div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px">
        <div style="background:var(--bg2);border-radius:6px;padding:8px 12px;font-size:11px;border:1.5px solid #1d9e75">
          <div style="font-size:9px;font-weight:500;color:#085041;margin-bottom:4px">FACT</div>
          <strong style="color:var(--text1)">FactRooms</strong>
          <div style="color:var(--text2);margin-top:4px;font-size:10px;line-height:1.6">
            RoomKey (PK)<br>BuildingKey<br>FloorKey<br>DeptKey<br>KSTKey<br>OrgKey<br>RoomTypeKey<br>AKH_m2<br>Raumbezeichnung
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;flex:1;min-width:220px">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
            <div style="background:var(--bg2);border-radius:6px;padding:8px 12px;font-size:10px;border:0.5px solid var(--border)">
              <div style="font-size:9px;color:var(--text2);margin-bottom:2px">DIM</div>
              <strong>DimBuilding</strong>
              <div style="color:var(--text2);margin-top:3px;line-height:1.6">BuildingKey · Gebäude · Gebäudename · Gebäudename_Lang</div>
            </div>
            <div style="background:var(--bg2);border-radius:6px;padding:8px 12px;font-size:10px;border:0.5px solid var(--border)">
              <div style="font-size:9px;color:var(--text2);margin-bottom:2px">DIM</div>
              <strong>DimFloor</strong>
              <div style="color:var(--text2);margin-top:3px;line-height:1.6">FloorKey · Etage · Etage_Label · Gebäude</div>
            </div>
            <div style="background:var(--bg2);border-radius:6px;padding:8px 12px;font-size:10px;border:0.5px solid var(--border)">
              <div style="font-size:9px;color:var(--text2);margin-bottom:2px">DIM</div>
              <strong>DimDepartment</strong>
              <div style="color:var(--text2);margin-top:3px;line-height:1.6">DeptKey · Fachbereich · Domäne · KST_Gruppe</div>
            </div>
            <div style="background:var(--bg2);border-radius:6px;padding:8px 12px;font-size:10px;border:0.5px solid var(--border)">
              <div style="font-size:9px;color:var(--text2);margin-bottom:2px">DIM</div>
              <strong>DimKST</strong>
              <div style="color:var(--text2);margin-top:3px;line-height:1.6">KSTKey · KST · KST_Bez · KST_Gruppe · KST_Akt</div>
            </div>
            <div style="background:var(--bg2);border-radius:6px;padding:8px 12px;font-size:10px;border:0.5px solid var(--border)">
              <div style="font-size:9px;color:var(--text2);margin-bottom:2px">DIM</div>
              <strong>DimOrganization</strong>
              <div style="color:var(--text2);margin-top:3px;line-height:1.6">OrgKey · Gesellschaft · Domäne · Direktion</div>
            </div>
            <div style="background:var(--bg2);border-radius:6px;padding:8px 12px;font-size:10px;border:0.5px solid var(--border)">
              <div style="font-size:9px;color:var(--text2);margin-bottom:2px">DIM</div>
              <strong>DimRoomType</strong>
              <div style="color:var(--text2);margin-top:3px;line-height:1.6">RoomTypeKey · Kategorie · Raumart · Fußbodenbelag</div>
            </div>
          </div>
        </div>
      </div>
      <div style="background:var(--bg3);border-radius:6px;padding:10px;font-size:10px">
        <div style="font-weight:500;margin-bottom:6px;color:var(--text1)">Kritische Datenqualitätsprobleme</div>
