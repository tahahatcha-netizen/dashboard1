function renderTreemap(){
  const el=document.getElementById('treemap');
  const W=el.offsetWidth||430,H=200;
  const total=DATA.orgDomains.reduce((s,d)=>s+d.area,0);
  let x=0;
  el.innerHTML='';
  DATA.orgDomains.forEach(dom=>{
    const w=Math.round(dom.area/total*W);
    const div=document.createElement('div');
    div.className='treemap-cell';
    div.style.cssText=`left:${x}px;top:0;width:${w}px;height:${H}px;background:${dom.color};border-radius:3px`;
    div.innerHTML=`<div class="treemap-label">${dom.label.split(' ')[0]}<br>${(dom.area/1000).toFixed(1)}k m²</div>`;
    el.appendChild(div);
    x+=w;
  });
}

